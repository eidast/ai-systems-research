{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eidast.github.io/ai-systems-research/schemas/benchmark-definition.schema.json",
  "title": "Benchmark Definition",
  "type": "object",
  "required": [
    "id",
    "name",
    "category",
    "benchmark_tier",
    "architectural_analog",
    "problem_statement",
    "semantic_equivalence_rules",
    "metrics",
    "inputs",
    "warmup"
  ],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "category": { "type": "string" },
    "benchmark_tier": { "type": "string", "enum": ["micro", "component", "reference-workload"] },
    "architectural_analog": { "type": "string" },
    "problem_statement": { "type": "string" },
    "semantic_equivalence_rules": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "allowed_libraries": { "type": "object" },
    "prohibited_shortcuts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "inputs": { "type": "object" },
    "metrics": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "warmup": {
      "type": "object",
      "required": ["iterations", "required"],
      "properties": {
        "iterations": { "type": "integer", "minimum": 0 },
        "required": { "type": "boolean" }
      }
    },
    "interpretation_limits": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
