{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eidast.github.io/ai-systems-research/schemas/benchmark-run.schema.json",
  "title": "Benchmark Run",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "benchmark",
    "implementation",
    "parameters",
    "metrics",
    "quality",
    "timestamps"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "run_id": { "type": "string" },
    "benchmark": {
      "type": "object",
      "required": ["id", "category", "benchmark_tier", "architectural_analog"],
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string" },
        "benchmark_tier": { "type": "string" },
        "architectural_analog": { "type": "string" }
      }
    },
    "implementation": {
      "type": "object",
      "required": ["language", "runtime", "mode", "implementation_version"],
      "properties": {
        "language": { "type": "string" },
        "runtime": { "type": "string" },
        "mode": { "type": "string" },
        "implementation_version": { "type": "string" }
      }
    },
    "parameters": {
      "type": "object",
      "required": ["input_size", "trial", "warmup_completed"],
      "properties": {
        "input_size": {},
        "trial": { "type": "integer", "minimum": 1 },
        "warmup_completed": { "type": "boolean" }
      }
    },
    "metrics": {
      "type": "object",
      "required": ["wall_time_ms", "cpu_percent_avg", "cpu_percent_peak", "mem_peak_mb", "exit_code"],
      "properties": {
        "wall_time_ms": { "type": "number" },
        "cpu_percent_avg": { "type": "number" },
        "cpu_percent_peak": { "type": "number" },
        "mem_peak_mb": { "type": "number" },
        "exit_code": { "type": "integer" }
      }
    },
    "quality": {
      "type": "object",
      "required": ["correctness_passed"],
      "properties": {
        "correctness_passed": { "type": "boolean" },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "timestamps": {
      "type": "object",
      "required": ["started_at", "finished_at"],
      "properties": {
        "started_at": { "type": "string" },
        "finished_at": { "type": "string" }
      }
    }
  },
  "additionalProperties": true
}
